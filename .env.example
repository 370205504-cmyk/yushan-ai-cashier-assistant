# ============================================================
# 雨姗AI收银助手 - 环境配置示例文件
# ============================================================
# 注意: 此文件仅作为配置参考，生产环境请复制为.env并修改敏感配置
# 敏感配置建议使用环境变量或密钥管理服务存储
# ============================================================

PORT=3000
NODE_ENV=development

# ============================================================
# 数据库配置
# ============================================================
# 生产环境建议创建专用数据库用户并设置强密码
DB_HOST=localhost
DB_PORT=3306
DB_USER=<DB_USERNAME>
DB_PASSWORD=<DB_PASSWORD>
DB_NAME=yushan_restaurant
DB_CONNECTION_LIMIT=20

# ============================================================
# Redis缓存配置
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_DB=0

# ============================================================
# 安全配置 (重要！生产环境必须修改)
# ============================================================
# JWT密钥 - 建议使用至少32位随机字符串
JWT_SECRET=<JWT_SECRET_KEY>
JWT_EXPIRES_IN=7d

# 加密密钥 - 用于敏感数据加密，至少32位
ENCRYPTION_KEY=<ENCRYPTION_KEY>

# ============================================================
# 支付配置 (敏感信息，请勿提交到版本控制)
# ============================================================
# 微信支付配置
WECHAT_APPID=<WECHAT_APPID>
WECHAT_MCHID=<WECHAT_MCHID>
WECHAT_APIKEY=<WECHAT_APIKEY>
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/callback

# 支付宝配置
ALIPAY_APPID=<ALIPAY_APPID>
ALIPAY_PRIVATE_KEY=<ALIPAY_PRIVATE_KEY>
ALIPAY_PUBLIC_KEY=<ALIPAY_PUBLIC_KEY>
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay/callback

# ============================================================
# 打印机配置
# ============================================================
PRINTER_IP=<PRINTER_IP>
PRINTER_PORT=9100

# ============================================================
# 限流与安全配置
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000

# ============================================================
# 备份配置
# ============================================================
BACKUP_PATH=/workspace/backups
BACKUP_RETENTION_DAYS=30

# ============================================================
# 管理员配置
# ============================================================
ADMIN_USER_IDS=1,2,3
ADMIN_PHONES=<ADMIN_PHONE>
ADMIN_API_KEY=<ADMIN_API_KEY>

# ============================================================
# HTTPS和SSL配置
# ============================================================
FORCE_HTTPS=false
UPGRADE_INSECURE_REQUESTS=false
CSP_REPORT_ONLY=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============================================================
# 企业微信机器人配置
# ============================================================
WW_WORK_TOKEN=<WW_WORK_TOKEN>
WW_WORK_ENCODING_AES_KEY=<WW_WORK_ENCODING_AES_KEY>
WW_WORK_APPID=<WW_WORK_APPID>

# ============================================================
# 环境变量安全说明
# ============================================================
# 1. 敏感配置标记:
#    - <DB_PASSWORD>          : 数据库密码
#    - <REDIS_PASSWORD>       : Redis密码
#    - <JWT_SECRET_KEY>       : JWT签名密钥
#    - <ENCRYPTION_KEY>       : 数据加密密钥
#    - <WECHAT_APIKEY>        : 微信支付密钥
#    - <ALIPAY_PRIVATE_KEY>   : 支付宝私钥
#    - <ADMIN_API_KEY>        : 管理员API密钥
#    - <WW_WORK_*>            : 企业微信配置

# 2. 安全建议:
#    - 生产环境禁止将敏感配置写入.env文件
#    - 使用环境变量注入敏感配置: export DB_PASSWORD="your_secret"
#    - 考虑使用密钥管理服务(如AWS KMS、Vault等)
#    - 定期轮换密码和密钥
#    - 限制配置文件访问权限: chmod 600 .env

# 3. 加密说明:
#    - 数据库连接密码使用AES-256加密存储
#    - 敏感API密钥使用HSM或密钥管理服务保护
#    - 日志中禁止打印密码和密钥信息
