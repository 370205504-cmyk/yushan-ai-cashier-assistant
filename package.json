    "cors": "2.8.5",
    "dompurify": "^3.4.3",
    "dotenv": "16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "7.0.1",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
