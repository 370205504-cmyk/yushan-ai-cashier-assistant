      {
        "name": "request_invoice",
        "description": "申请开具发票",
        "inputSchema": {
          "type": "object",
          "properties": {
            "order_no": {
              "type": "string",
              "description": "订单号"
            },
            "invoice_type": {
              "type": "string",
              "description": "发票类型：personal(个人)或company(企业)",
              "enum": ["personal", "company"]
            },
            "invoice_title": {
              "type": "string",
              "description": "发票抬头"
            },
            "tax_number": {
              "type": "string",
              "description": "税号（企业发票必填）"
            },
            "company_address": {
              "type": "string",
              "description": "公司地址（企业发票）"
            },
            "company_phone": {
              "type": "string",
              "description": "公司电话（企业发票）"
            },
            "bank_name": {
              "type": "string",
              "description": "开户银行（企业发票）"
            },
            "bank_account": {
              "type": "string",
              "description": "银行账号（企业发票）"
            },
            "email": {
              "type": "string",
              "description": "接收邮箱"
            },
            "phone": {
              "type": "string",
              "description": "接收电话"
            },
            "remark": {
              "type": "string",
              "description": "备注"
            }
          },
          "required": ["order_no", "invoice_type", "invoice_title"]
        },
        "examples": [
          {"order_no": "ORD20260115001", "invoice_type": "personal", "invoice_title": "个人", "email": "user@example.com"},
          {"order_no": "ORD20260115002", "invoice_type": "company", "invoice_title": "某某公司", "tax_number": "91110000XXXXX", "email": "finance@company.com"}
        ]
      },
      {
        "name": "get_invoice_status",
