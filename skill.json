          "type": "object",
          "properties": {
            "order_no": {
              "type": "string",
              "description": "订单号"
            },
            "invoice_id": {
              "type": "string",
              "description": "发票ID（可选）"
            }
          },
          "required": ["order_no"]
        },
        "examples": [
          {"order_no": "ORD20260115001"}
        ]
      },
      {
        "name": "create_delivery_order",
        "description": "创建外卖配送订单",
        "inputSchema": {
          "type": "object",
          "properties": {
            "order_no": {
              "type": "string",
              "description": "订单号"
            },
            "store_id": {
              "type": "string",
