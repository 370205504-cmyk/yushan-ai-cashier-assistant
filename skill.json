          },
          "required": ["order_no", "store_id", "delivery_address", "contact_name", "contact_phone", "delivery_fee"]
        },
        "examples": [
          {"order_no": "ORD20260115001", "store_id": "1", "delivery_address": "县某某小区1号楼1单元101室", "contact_name": "张先生", "contact_phone": "13800138000", "delivery_fee": 3}
        ]
      },
      {
        "name": "track_delivery",
        "description": "跟踪配送状态",
