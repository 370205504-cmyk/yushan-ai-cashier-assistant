# ============================================================
# 雨姗AI收银助手 - 生产环境配置模板
# ============================================================
# 生产环境安全要求:
# 1. 所有敏感配置必须通过环境变量注入
# 2. 禁止在配置文件中存储明文密码
# 3. 使用密钥管理服务管理敏感信息
# 4. 定期轮换密钥和密码
# ============================================================

# 基础配置
PORT=443
NODE_ENV=production

# ============================================================
# 数据库配置 - 生产环境建议使用独立数据库服务器
# ============================================================
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT:-3306}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_NAME=yushan_restaurant_prod
DB_CONNECTION_LIMIT=50

# ============================================================
# Redis配置 - 生产环境建议使用哨兵或集群模式
# ============================================================
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT:-6379}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0
REDIS_CLUSTER_MODE=false

# ============================================================
# 安全配置 - 生产环境必须使用强密钥
# ============================================================
# JWT密钥 - 使用至少64位随机字符串
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=24h

# 加密密钥 - 使用至少32位随机字符串
ENCRYPTION_KEY=${ENCRYPTION_KEY}

# ============================================================
# 支付配置 - 使用环境变量注入敏感信息
# ============================================================
WECHAT_APPID=${WECHAT_APPID}
WECHAT_MCHID=${WECHAT_MCHID}
WECHAT_APIKEY=${WECHAT_APIKEY}
WECHAT_NOTIFY_URL=https://your-production-domain.com/api/v1/payment/wechat/callback

ALIPAY_APPID=${ALIPAY_APPID}
ALIPAY_PRIVATE_KEY=${ALIPAY_PRIVATE_KEY}
ALIPAY_PUBLIC_KEY=${ALIPAY_PUBLIC_KEY}
ALIPAY_NOTIFY_URL=https://your-production-domain.com/api/v1/payment/alipay/callback

# ============================================================
# 打印机配置
# ============================================================
PRINTER_IP=${PRINTER_IP}
PRINTER_PORT=9100

# ============================================================
# 安全策略配置
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
CORS_ORIGIN=https://your-production-domain.com

# 强制HTTPS
FORCE_HTTPS=true
UPGRADE_INSECURE_REQUESTS=true
CSP_REPORT_ONLY=false

# SSL证书配置
SSL_CERT_PATH=/etc/ssl/certs/your-domain.crt
SSL_KEY_PATH=/etc/ssl/private/your-domain.key

# ============================================================
# 备份配置 - 生产环境建议配置远程备份
# ============================================================
BACKUP_PATH=/var/backups/yushan
BACKUP_RETENTION_DAYS=90
CLOUD_STORAGE_URL=${CLOUD_STORAGE_URL}

# ============================================================
# 管理员配置
# ============================================================
ADMIN_USER_IDS=${ADMIN_USER_IDS}
ADMIN_PHONES=${ADMIN_PHONES}
ADMIN_API_KEY=${ADMIN_API_KEY}

# ============================================================
# 企业微信机器人配置
# ============================================================
WW_WORK_TOKEN=${WW_WORK_TOKEN}
WW_WORK_ENCODING_AES_KEY=${WW_WORK_ENCODING_AES_KEY}
WW_WORK_APPID=${WW_WORK_APPID}

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=warn
LOG_FILE=/var/log/yushan/app.log
LOG_MAX_SIZE=100M
LOG_MAX_FILES=30

# ============================================================
# 性能配置
# ============================================================
NODE_OPTIONS=--max-old-space-size=4096
WORKER_PROCESSES=4

# ============================================================
# 生产环境部署说明
# ============================================================
# 1. 配置注入方式:
#    export DB_PASSWORD="your-strong-password"
#    export JWT_SECRET="your-64-char-secret"
#    export ENCRYPTION_KEY="your-32-char-encryption-key"
#    npm start

# 2. 推荐使用Docker Secrets或Kubernetes Secrets
#    - Docker: docker secret create db_password -
#    - Kubernetes: kubectl create secret generic db-secret --from-literal=password=xxx

# 3. 密钥生成命令:
#    # 生成64位JWT密钥
#    openssl rand -hex 32
#    # 生成32位加密密钥
#    openssl rand -hex 16

# 4. 安全检查清单:
#    - [ ] 禁用DEBUG模式
#    - [ ] 启用HTTPS
#    - [ ] 配置防火墙规则
#    - [ ] 禁用目录列出
#    - [ ] 配置日志轮转
#    - [ ] 定期备份数据库
#    - [ ] 配置监控告警
